        <script><![CDATA[(function executeRule(current, previous) {
    var ritm = current.request_item;
    if (!ritm) return;
    var reqSysId = ritm.request;
    if (!reqSysId) return;

    // فيه أي مهمة تسليم مفتوحة تانية؟
    var openTasks = new GlideRecord('sc_task');
    openTasks.addQuery('request_item.request', reqSysId);
    openTasks.addQuery('state', '!=', 3);
    openTasks.addQuery('short_description', 'STARTSWITH', 'تسليم الدواء');
    openTasks.setLimit(1);
    openTasks.query();

    if (!openTasks.hasNext()) {
        var req = new GlideRecord('sc_request');
        if (req.get(reqSysId)) {
            req.state = 'closed_complete';
            req.update();
        }
    }
})(current, previous);]]></script>
