        <script><![CDATA[(function executeRule(current, previous /*, gR */) {

    var medicineSysId = current.variables.medicine_name;
    if (!medicineSysId) {
        return;
    }

    var qty = parseInt(current.variables.quantity_needed);
    if (isNaN(qty) || qty <= 0) {
        return;
    }

    var gr = new GlideRecord('x_1971078_smart_0_medicine_inventory');
    if (gr.get(medicineSysId)) {
        var newStock = parseInt(gr.quantity) + qty;
        gr.quantity = newStock < 0 ? 0 : newStock;
        gr.update();
        
        gs.info('RevertStock: Successfully reverted ');
    }
    current.update();

    

})(current, previous);]]></script>
