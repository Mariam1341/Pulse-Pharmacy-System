        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
   if (isLoading || newValue == '') {
      return;
   }

   // Get the selected date
    var selectedDate = new Date(newValue);
    var today = new Date();
    
    // Reset time to midnight for accurate date comparison
    today.setHours(0, 0, 0, 0);
    
    // If selected date is before today, it's a past date
    if (selectedDate < today) {
        g_form.showFieldMsg('preferred_pickup_date', '❌ Cannot select a past date. Please choose today or a future date.', 'error');

        return;
    }
    
    // Clear any previous error message if date is valid
    g_form.hideFieldMsg('preferred_pickup_date');
   
}]]></script>
