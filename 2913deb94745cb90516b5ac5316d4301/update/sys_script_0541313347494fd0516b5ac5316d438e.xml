        <script><![CDATA[(function executeRule(current, previous /* null when async */) {

    if (!current.stage.changesTo('approved')) {
        return;
    }
    var medicineId = current.variables.medicine_name;

    if (!medicineId) {
        gs.addErrorMessage('Request error: No medicine selected.');
        current.setAbortAction(true);
        return;
    }

    var gr = new GlideRecord('x_1971078_smart_0_medicine_inventory');
    if (!gr.get(medicineId)) {
        gs.addErrorMessage('Technical error: Medicine not found in inventory.');
        current.setAbortAction(true);
        return;
    }

    var medName = gr.medicine_name;
    var medStatus = gr.status;

    // 4. Block approval if the medicine is expired
    if (medStatus == 'expired') {
        var errorMsg = 'Cannot approve this request. The medicine "' + medName + '" has expired.';
        gs.addErrorMessage(errorMsg);
        current.setAbortAction(true);
        return;
    }

})(current, previous);]]></script>
